# Supabase — copie para .env.local
# Dashboard Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key-aqui
# Legado (opcional): NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NUNCA use prefixo NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# UID do superadmin (auth.users.id) — necessário para session-action
SUPERADMIN_UID=seu-uuid-aqui

# Build ID estável (opcional)
# NEXT_PUBLIC_BUILD_ID=migra-stable-v1

# Genkit / Google AI
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
