# Supabase — copie para .env.local
# Dashboard Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key-aqui
# Legado (opcional): NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NUNCA use prefixo NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Opcional — Management API (npm run db:configure-auth)
# https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=nisaukwqrdyomvrczwrf

# UID do superadmin (auth.users.id) — gere com: node scripts/seed-master-user.mjs
SUPERADMIN_UID=seu-uuid-aqui
NEXT_PUBLIC_SUPERADMIN_UID=seu-uuid-aqui

# URL pública da aplicação (links em e-mails de primeiro acesso)
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com

# Build ID estável (opcional)
# NEXT_PUBLIC_BUILD_ID=migra-stable-v1

# Genkit / Google AI
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
